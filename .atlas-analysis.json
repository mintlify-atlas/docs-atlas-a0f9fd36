  "keyFeatures": [
    "Real-time collaborative editing with Yjs CRDT",
    "Live PlantUML diagram preview",
    "Public and private rooms with access control",
    "SVG diagram export",
    "Offline sync with cross-tab communication",
    "Guest and authenticated user support",
    "Monaco code editor integration",
    "WebSocket-based real-time updates"
  ],
  "publicApiSurface": [
    "POST /auth/signup",
    "POST /auth/login",
    "GET /auth/guest",
    "GET /auth/verify",
    "POST /room/:room_name",
    "GET /room/public/:room_name",
    "GET /room/private/:owner_id/:room_name",
    "PUT /room/:room_id/access",
    "PUT /room/share/:room_id",
    "GET /room/:room_id/uml",
    "POST /room/:room_id/document/:document_name",
    "PUT /room/:room_id/document/:document_id/rename",
    "GET /user/displayname"
  ]
}
